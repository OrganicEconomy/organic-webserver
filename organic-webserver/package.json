{
  "name": "organic-webserver",
  "version": "1.0.0",
  "description": "A REST API to serve the organic webapp",
  "keywords": [
    "organic",
    "money",
    "rest",
    "javascript"
  ],
  "license": "MIT",
  "author": "Gus",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node --import tsx server.ts",
    "server": "NODE_ENV=dev node --env-file=../.env.dev --import tsx server.ts",
    "winserver": "SET NODE_ENV=dev& node --env-file=../.env.dev --import tsx server.ts",
    "test": "NODE_ENV=test node --env-file=../.env.test --import tsx ./node_modules/mocha/bin/mocha",
    "wintest": "SET NODE_ENV=test& node --env-file=../.env.test --import tsx ./node_modules/mocha/bin/mocha",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "organic-money": "^0.3.0",
    "organic-protocol": "^0.2.0",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "mocha": "^11.7.6",
    "supertest": "^7.2.2",
    "typescript": "^7.0.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sqlite3@6.0.1": true
  }
}
